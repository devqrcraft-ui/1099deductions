{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "1099deductions.com"
        }
      ],
      "destination": "https://www.1099deductions.com/$1",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/deductions/(.+\\.html)",
      "dest": "/deductions/$1"
    },
    {
      "src": "/deductions/(.*)",
      "dest": "/deductions/$1"
    },
    {
      "src": "/deadlines.html",
      "dest": "/deadlines.html"
    },
    {
      "src": "/(.+\\.js)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.css)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.png)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.ico)",
      "dest": "/$1"
    },
    {
      "src": "/(.+\\.xml)",
      "dest": "/$1"
    },
    {
      "src": "/doordash-tax-deductions-2026",
      "dest": "/doordash-tax-deductions-2026.html"
    },
    {
      "src": "/uber-driver-tax-deductions-2026",
      "dest": "/uber-driver-tax-deductions-2026.html"
    },
    {
      "src": "/onlyfans-tax-deductions-2026",
      "dest": "/onlyfans-tax-deductions-2026.html"
    },
    {
      "src": "/airbnb-host-tax-deductions-2026",
      "dest": "/airbnb-host-tax-deductions-2026.html"
    },
    {
      "src": "/instacart-tax-deductions-2026",
      "dest": "/instacart-tax-deductions-2026.html"
    },
    {
      "src": "/1099-tax-deductions-california-2026",
      "dest": "/1099-tax-deductions-california-2026.html"
    },
    {
      "src": "/1099-tax-deductions-texas-2026",
      "dest": "/1099-tax-deductions-texas-2026.html"
    },
    {
      "src": "/1099-tax-deductions-new-york-2026",
      "dest": "/1099-tax-deductions-new-york-2026.html"
    },
    {
      "src": "/1099-tax-deductions-florida-2026",
      "dest": "/1099-tax-deductions-florida-2026.html"
    },
    {
      "src": "/app-data.js",
      "dest": "/app-data.js",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.+\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=86400, stale-while-revalidate=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.+\\.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.+\\.css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}