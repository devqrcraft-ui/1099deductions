{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "1099deductions.com"
        }
      ],
      "destination": "https://www.1099deductions.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.js$|.*\\.css$|.*\\.png$|.*\\.ico$|.*\\.xml$|.*\\.txt$).*)",
      "destination": "/index.html"
    }
  ]
}